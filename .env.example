# Database
# For local dev, SQLite is used automatically (no setup needed)
# For production, switch to PostgreSQL:
# DATABASE_URL="postgresql://user:password@localhost:5432/empathy_game"
DATABASE_URL="file:./dev.db"

# Scoring Engine
# Options: "heuristic" | "llm"
# Use "heuristic" locally without an API key; switch to "llm" for richer feedback
SCORING_PROVIDER="heuristic"

# Anthropic API (only needed if SCORING_PROVIDER=llm)
ANTHROPIC_API_KEY="sk-ant-..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin secret — used to verify admin-level API calls
# Generate with: openssl rand -hex 32
ADMIN_SECRET="change-me-in-production"
