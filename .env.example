# Database — Vercel Postgres (Neon)
# Copy these from the Vercel dashboard after adding a Postgres store:
#   Project → Storage → Postgres → .env.local tab
POSTGRES_PRISMA_URL="postgres://user:password@host/db?pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgres://user:password@host/db"

# Scoring Engine
# Options: "heuristic" | "llm"
# Use "heuristic" locally without an API key; switch to "llm" for richer feedback
SCORING_PROVIDER="heuristic"

# Anthropic API (only needed if SCORING_PROVIDER=llm)
ANTHROPIC_API_KEY="sk-ant-..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin secret — used to verify admin-level API calls
# Generate with: openssl rand -hex 32
ADMIN_SECRET="change-me-in-production"
